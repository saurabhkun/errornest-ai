# Database connection url (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@hostname:5432/databasename?sslmode=require"

# Auth.js / NextAuth settings
# Run 'npx auth secret' or 'openssl rand -base64 33' to generate a secure secret
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# OAuth Credentials
AUTH_GOOGLE_ID="google-client-id"
AUTH_GOOGLE_SECRET="google-client-secret"
AUTH_GITHUB_ID="github-client-id"
AUTH_GITHUB_SECRET="github-client-secret"

# Resend Transactional Email Settings
RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="ErrorNest <noreply@yourdomain.com>"

# Upstash Redis settings (Rate limiting & queues)
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# AI Assistant Settings (Gemini API)
GEMINI_API_KEY="your-gemini-api-key"
AI_DAILY_LIMIT="50"

# Application Settings
APP_URL="http://localhost:3000"
INGESTION_MAX_BYTES="204800" # 200 KB in bytes
CRON_SECRET="your-secured-cron-secret-token"
