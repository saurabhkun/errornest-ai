# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing & reports
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.local-browsers/

# next.js
/.next/
/out/

# production build
/build

# misc
.DS_Store
Thumbs.db
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (allow .env.example)
.env*
!.env.example

# vercel
.vercel

# typescript build cache
*.tsbuildinfo
next-env.d.ts

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
